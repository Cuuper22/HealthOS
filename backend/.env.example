# HealthOS Backend Configuration

# Database Configuration
# SQLite example (default): sqlite:///./data/database/healthos.db
# PostgreSQL example: postgresql://user:password@localhost/healthos
HEALTHOS_DATABASE_URL=sqlite:///../data/database/healthos.db

# Security Configuration
# CRITICAL: Change this in production! Generate with: openssl rand -hex 32
HEALTHOS_SECRET_KEY=change-me-in-production-use-strong-random-key

# JWT Configuration
HEALTHOS_ALGORITHM=HS256
HEALTHOS_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Application Configuration
HEALTHOS_APP_NAME=HealthOS
HEALTHOS_ENVIRONMENT=development

# Logging Configuration
HEALTHOS_LOG_LEVEL=INFO

# Encryption Key (for sensitive data encryption)
# CRITICAL: Change this in production! Generate with: openssl rand -hex 32
HEALTHOS_ENCRYPTION_KEY=change-me-in-production-use-strong-random-key

# Rate Limiting (requests per minute)
HEALTHOS_RATE_LIMIT_AUTH=5
HEALTHOS_RATE_LIMIT_API=60

# Email Configuration (for password reset)
HEALTHOS_SMTP_HOST=smtp.gmail.com
HEALTHOS_SMTP_PORT=587
HEALTHOS_SMTP_USER=your-email@example.com
HEALTHOS_SMTP_PASSWORD=your-app-password
HEALTHOS_FROM_EMAIL=noreply@healthos.example.com
HEALTHOS_FRONTEND_URL=http://localhost:5173
